# Szablon zmiennych srodowiskowych dla docker-compose.
# Skopiuj do .env i ustaw wlasne wartosci:  cp .env.example .env
# Plik .env jest w .gitignore - prawdziwe hasla NIE trafiaja do repo.
#
# Bez .env compose uzyje wartosci domyslnych (apex/apex) z docker-compose.yml.

DB_USERNAME=apex
DB_PASSWORD=apex
